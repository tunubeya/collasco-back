generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DEVELOPER
  TESTER
}


enum ProjectStatus {
  ACTIVE
  ON_HOLD
  FINISHED
}

enum Visibility {
  PRIVATE
  PUBLIC
}

enum FeaturePriority {
  LOW
  MEDIUM
  HIGH
}

enum FeatureStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum ReviewStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

enum TestEvaluation {
  NOT_STARTED
  NOT_WORKING
  MINOR_ISSUE
  PASSED
}

enum TestRunStatus {
  OPEN
  CLOSED
}

enum DocumentationEntityType {
  FEATURE
  MODULE
  PROJECT
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  passwordHash     String
  name             String?
  role             UserRole
  isActive         Boolean            @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  // Identidad GitHub (token por usuario; acciones en nombre del user)
  githubIdentity   GithubIdentity?
  // Trazabilidad
  modifiedModules  Module[]           @relation("ModuleLastModifiedBy")
  modifiedFeatures Feature[]          @relation("FeatureLastModifiedBy")
  createdModuleVs  ModuleVersion[]    @relation("ModuleVersionCreatedBy")
  createdFeatureVs FeatureVersion[]   @relation("FeatureVersionCreatedBy")
  // Tokens de sesión
  UserRefreshToken UserRefreshToken[]
  passwordResetTokens PasswordResetToken[]
  // 🔥 Proyectos que posee
  ownedProjects    Project[]          @relation("ProjectOwner")
  // 🔥 Membresías N:M por proyecto (permisos por proyecto)
  memberships      ProjectMember[]
  projectPreferences UserProjectPreference[]
  manualShareLinks ManualShareLink[]
  TestRun          TestRun[]
  deletedProjects  Project[]          @relation("ProjectDeletedBy")
  deletedModules   Module[]           @relation("ModuleDeletedBy")
  deletedFeatures  Feature[]          @relation("FeatureDeletedBy")
  deletedProjectLabels ProjectLabel[] @relation("ProjectLabelDeletedBy")
  createdDocumentationImages DocumentationImage[] @relation("DocumentationImageCreatedBy")
  notifications               Notification[]
  createdTickets              Ticket[]          @relation("TicketCreatedBy")
  assignedTickets             Ticket[]          @relation("TicketAssignee")
  ticketSections              TicketSection[]
  lockedSections              TicketSection[]   @relation("TicketSectionLockedBy")
  createdShareLinks           TicketShareLink[] @relation("TicketShareLinkCreatedBy")
  ticketImages               TicketImage[]
  // Tickets donde el usuario recibe notificaciones in-app
  notifyTickets              TicketNotifyUser[]
  // Tickets donde el usuario recibe emails
  emailTickets               TicketEmailUser[]
  // Receipts de lectura de tickets
  ticketReadReceipts         TicketReadReceipt[]
  // Preferencias globales de notificaciones de tickets
  notifyAssignedTickets     Boolean @default(false)
  notifyUnassignedTickets  Boolean @default(false)
  emailAssignedTickets     Boolean @default(false)
  emailUnassignedTickets  Boolean @default(false)
}

model UserRefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model GithubIdentity {
  id          String    @id @default(uuid())
  userId      String    @unique
  //refreshToken String?
  //tokenType    String? // "Bearer"
  //scopes       String? // "repo,workflow"
  expiresAt   DateTime?
  accessToken String // ⚠️ ideal: cifrado en reposo
  username    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id               String                   @id @default(uuid())
  name             String
  slug             String?
  description      String?
  status           ProjectStatus            @default(ACTIVE)
  repositoryUrl    String?
  visibility       Visibility               @default(PRIVATE)
  deadline         DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  // 🔥 Dueño real del proyecto (User)
  ownerId          String
  owner            User                     @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // 🔥 Miembros N:M con rol
  members          ProjectMember[]
  roles            ProjectRole[]
  // 🔥 Credencial GitHub 1:1 (token del repo/proyecto)
  githubCredential ProjectGithubCredential?
  // Estructura funcional
  modules          Module[]
  testRuns         TestRun[]
  labels           ProjectLabel[]
  documentationEntries DocumentationField[]
  userPreferences  UserProjectPreference[]
  manualShareLinks ManualShareLink[]
  documentationImages DocumentationImage[]
  tickets            Ticket[]
  shareLinks         TicketShareLink[]
  deletedAt        DateTime?
  deletedById      String?
  deletedBy        User?                    @relation("ProjectDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([deletedAt])
}

model ManualShareLink {
  id          String   @id @default(uuid())
  projectId   String
  createdById String
  labelIds    String[] @default([])
  comment     String?
  rootType    DocumentationEntityType?
  rootId      String?
  createdAt   DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdById])
}

model ProjectMember {
  projectId String
  userId    String
  roleId    String
  joinedAt  DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    ProjectRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([projectId, userId])
  @@index([userId])
  @@index([roleId])
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions ProjectRolePermission[]
}

model ProjectRole {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  isOwner     Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project           Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members           ProjectMember[]
  rolePermissions   ProjectRolePermission[]
  visibleInLabels   ProjectLabelVisibleRole[]
  readOnlyInLabels  ProjectLabelReadOnlyRole[]

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectRolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       ProjectRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ProjectGithubCredential {
  id           String    @id @default(uuid())
  projectId    String    @unique
  accessToken  String // ⚠️ Ideal: cifrado en reposo
  refreshToken String?
  tokenType    String?
  scopes       String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Module {
  id                 String   @id @default(uuid())
  projectId          String
  parentModuleId     String?
  name               String
  description        String?
  isRoot             Boolean  @default(false)
  sortOrder          Int      @default(0)
  path               String? // ej: "root/abc/def"
  depth              Int? // ej: 0=root, 1=hijo, etc.
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastModifiedById   String?
  publishedVersionId String?
  deletedAt          DateTime?
  deletedById        String?

  project             Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent              Module?            @relation("ModuleChildren", fields: [parentModuleId], references: [id], onDelete: SetNull)
  children            Module[]           @relation("ModuleChildren")
  features            Feature[]
  versions            ModuleVersion[]
  lastModifiedBy      User?              @relation("ModuleLastModifiedBy", fields: [lastModifiedById], references: [id], onDelete: SetNull)
  publishedVersion    ModuleVersion?     @relation("ModulePublished", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  deletedBy           User?              @relation("ModuleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  documentationFields DocumentationField[] @relation("ModuleDocumentation")

  @@unique([projectId, parentModuleId, name])
  @@index([publishedVersionId])
  @@index([projectId, parentModuleId, sortOrder])
  @@index([deletedAt])
}

model ModuleVersion {
  id             String   @id @default(uuid())
  moduleId       String
  versionNumber  Int
  name           String?
  description    String?
  parentModuleId String?
  isRoot         Boolean?
  changelog      String?
  createdById    String?
  createdAt      DateTime @default(now())
  isRollback     Boolean  @default(false)

  // 🔒 Congela el árbol en ese momento
  childrenPins Json? // [{ "moduleId": "mod-B", "versionNumber": 2 }, ...]
  featurePins  Json? // [{ "featureId": "feat-9", "versionNumber": 4 }, ...]
  module       Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdBy    User?  @relation("ModuleVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  publishedFor Module[] @relation("ModulePublished")

  contentHash String?

  @@unique([moduleId, contentHash])
  @@unique([moduleId, versionNumber])
  @@index([moduleId, versionNumber])
}

model Feature {
  id                 String           @id @default(uuid())
  moduleId           String
  name               String
  description        String?
  priority           FeaturePriority?
  status             FeatureStatus?   @default(PENDING)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  lastModifiedById   String?
  publishedVersionId String?
  sortOrder          Int              @default(0)
  deletedAt          DateTime?
  deletedById        String?

  module             Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  versions           FeatureVersion[]
  issueElements      IssueElement[]
  testCases          TestCase[]
  testRuns           TestRun[]
  lastModifiedBy     User?            @relation("FeatureLastModifiedBy", fields: [lastModifiedById], references: [id], onDelete: SetNull)
  publishedVersion   FeatureVersion?  @relation("FeaturePublished", fields: [publishedVersionId], references: [id], onDelete: SetNull)
  deletedBy          User?            @relation("FeatureDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  linkedFeatures     FeatureLink[]    @relation("FeatureLink_feature")
  linkedByFeatures   FeatureLink[]    @relation("FeatureLink_linked")
  initiatedLinks     FeatureLink[]    @relation("FeatureLink_initiator")
  documentationFields DocumentationField[] @relation("FeatureDocumentation")
  tickets             Ticket[]

  @@unique([moduleId, name])
  @@index([publishedVersionId])
  @@index([moduleId, priority, status])
  @@index([moduleId, sortOrder])
  @@index([deletedAt])
}

model FeatureVersion {
  id            String           @id @default(uuid())
  featureId     String
  versionNumber Int
  name          String?
  description   String?
  priority      FeaturePriority?
  status        FeatureStatus?
  changelog     String?
  createdById   String?
  createdAt     DateTime         @default(now())
  isRollback    Boolean          @default(false)

  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("FeatureVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  publishedFor Feature[] @relation("FeaturePublished")

  contentHash String?

  @@unique([featureId, contentHash])
  @@unique([featureId, versionNumber])
  @@index([featureId, versionNumber])
}

model IssueElement {
  id                String        @id @default(uuid())
  featureId         String
  githubIssueUrl    String?
  pullRequestUrl    String?
  repoOwner         String?
  repoName          String?
  githubIssueNumber Int?
  githubPrNumber    Int?
  commitHashes      String[]
  reviewStatus      ReviewStatus?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  feature           Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
  @@index([repoOwner, repoName, githubIssueNumber])
  @@index([repoOwner, repoName, githubPrNumber])
}

model TestCase {
  id         String   @id @default(uuid())
  featureId  String
  name       String
  steps      String?
  expected   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isArchived Boolean  @default(false)

  feature Feature      @relation(fields: [featureId], references: [id], onDelete: Cascade)
  results TestResult[]

  @@unique([featureId, name])
  @@index([featureId])
}

model TestRun {
  id        String   @id @default(uuid())
  projectId String
  featureId String?
  runDate   DateTime @default(now())
  runById   String?
  notes     String?
  name      String   @default("Unnamed run")
  environment String @default("unspecified")
  targetCaseIds String[] @default([])
  isTargetScopeCustom Boolean @default(false)
  createdAt DateTime @default(now())
  deletedAt DateTime?
  status    TestRunStatus @default(OPEN)

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  runBy   User?       @relation(fields: [runById], references: [id], onDelete: SetNull)
  results TestResult[]

  @@index([featureId, runDate])
  @@index([projectId, runDate])
  @@index([deletedAt])
}

model TestResult {
  id         String         @id @default(uuid())
  testRunId  String
  testCaseId String
  evaluation TestEvaluation @default(NOT_STARTED)
  comment    String?
  createdAt  DateTime       @default(now())

  testRun  TestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCase TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)

  @@unique([testRunId, testCaseId])
  @@index([testCaseId])
}

model FeatureLink {
  id              String   @id @default(uuid())
  featureId       String
  linkedFeatureId String
  createdAt       DateTime @default(now())
  reason          String?
  initiatorFeatureId String

  feature         Feature @relation("FeatureLink_feature", fields: [featureId], references: [id], onDelete: Cascade)
  linkedFeature   Feature @relation("FeatureLink_linked", fields: [linkedFeatureId], references: [id], onDelete: Cascade)
  initiatorFeature Feature @relation("FeatureLink_initiator", fields: [initiatorFeatureId], references: [id], onDelete: Cascade)

  @@unique([featureId, linkedFeatureId])
  @@index([featureId])
  @@index([linkedFeatureId])
  @@index([initiatorFeatureId])
}

model ProjectLabel {
  id             String              @id @default(uuid())
  projectId      String
  name           String
  instructions   String?
  isMandatory    Boolean             @default(false)
  defaultNotApplicable Boolean       @default(false)
  displayOrder   Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  deletedById    String?

  project             Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deletedBy           User?                @relation("ProjectLabelDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  documentationFields DocumentationField[]
  documentationImages DocumentationImage[]
  visibleRoles        ProjectLabelVisibleRole[]
  readOnlyRoles       ProjectLabelReadOnlyRole[]

  @@unique([projectId, name])
  @@index([projectId])
  @@index([projectId, displayOrder])
  @@index([deletedAt])
}

model ProjectLabelVisibleRole {
  labelId String
  roleId  String

  label ProjectLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  role  ProjectRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([labelId, roleId])
  @@index([roleId])
}

model ProjectLabelReadOnlyRole {
  labelId String
  roleId  String

  label ProjectLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  role  ProjectRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([labelId, roleId])
  @@index([roleId])
}

model DocumentationImage {
  id          String                  @id @default(uuid())
  projectId   String
  entityType  DocumentationEntityType
  entityId    String
  labelId     String
  name        String
  url         String
  mimeType    String
  size        Int
  createdAt   DateTime                @default(now())
  createdById String?

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     ProjectLabel  @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("DocumentationImageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([projectId, name])
  @@index([projectId])
  @@index([labelId])
  @@index([entityType, entityId])
}

model DocumentationField {
  id              String                   @id @default(uuid())
  projectId       String
  entityType      DocumentationEntityType
  featureId       String?
  moduleId        String?
  labelId         String
  content         String?
  isNotApplicable Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature Feature? @relation("FeatureDocumentation", fields: [featureId], references: [id], onDelete: Cascade)
  module  Module?  @relation("ModuleDocumentation", fields: [moduleId], references: [id], onDelete: Cascade)
  label   ProjectLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([projectId, entityType, featureId, moduleId, labelId])
  @@index([labelId])
  @@index([featureId])
  @@index([moduleId])
  @@index([projectId])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
}

enum TicketSectionType {
  DESCRIPTION
  RESPONSE
  COMMENT
}

model Ticket {
  id                String         @id @default(uuid())
  projectId         String
  featureId         String?
  title             String
  assigneeId        String?
  status            TicketStatus   @default(OPEN)
  createdById       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  followUpToken     String?        @unique
  publicReporterEmail String?
  publicReporterName  String?
  version           Int            @default(1)

  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  feature           Feature?       @relation(fields: [featureId], references: [id], onDelete: SetNull)
  assignee          User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy         User?          @relation("TicketCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  sections          TicketSection[]
  images            TicketImage[]
  shareLink         TicketShareLink? @relation("TicketShareLink", fields: [shareLinkId], references: [id])
  shareLinkId       String?        @unique
  // Lista de usuarios a notificar in-app
  notifyUsers       TicketNotifyUser[]
  // Lista de usuarios a enviar email
  emailUsers        TicketEmailUser[]
  // Receipts de lectura por usuario
  readReceipts      TicketReadReceipt[]

  @@index([projectId])
  @@index([featureId])
  @@index([createdById])
  @@index([followUpToken])
}

model TicketNotifyUser {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
}

model TicketEmailUser {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
}

model TicketReadReceipt {
  id              String   @id @default(uuid())
  userId          String
  ticketId        String
  lastSeenVersion Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticketId])
  @@index([ticketId])
}

model TicketShareLink {
  id          String    @id @default(uuid())
  projectId   String
  token       String    @unique
  name       String?
  createdById String
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("TicketShareLinkCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  ticket    Ticket?  @relation("TicketShareLink")

  @@index([projectId])
  @@index([createdById])
  @@index([token])
}

model TicketSection {
  id          String           @id @default(uuid())
  ticketId    String
  type        TicketSectionType
  title       String?
  content     String
  authorId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lockedAt    DateTime?
  lockedById  String?

  ticket      Ticket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author      User?            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  lockedBy    User?            @relation("TicketSectionLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([authorId])
  @@index([lockedById])
}

model TicketImage {
  id          String   @id @default(uuid())
  ticketId    String
  name        String
  url         String
  mimeType    String
  size        Int
  uploadedById String?
  createdAt   DateTime @default(now())

  ticket     Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User?    @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@unique([ticketId, name])
  @@index([ticketId])
}

model UserProjectPreference {
  userId                String
  projectId             String
  documentationLabelIds String[] @default([])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
  @@index([projectId])
}
